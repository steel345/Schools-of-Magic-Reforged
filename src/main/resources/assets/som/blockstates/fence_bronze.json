{
    "multipart": [
        {
            "apply": { "model": "som:block/bronze_fence_post" }
        },
        {
            "when": { "north": "true" },
            "apply": { "model": "som:block/bronze_fence_side" }
        },
        {
            "when": { "east": "true" },
            "apply": { "model": "som:block/bronze_fence_side", "y": 90 }
        },
        {
            "when": { "south": "true" },
            "apply": { "model": "som:block/bronze_fence_side", "y": 180 }
        },
        {
            "when": { "west": "true" },
            "apply": { "model": "som:block/bronze_fence_side", "y": 270 }
        }
    ]
}
